# Copie para .env e preencha as chaves. Nunca commite o arquivo .env com chaves reais.

# Assistente IA (recomendações de restaurantes + pratos) — usa Claude
# Obtenha em: https://console.anthropic.com/
# Use só o valor da chave, sem aspas. Ex.: VITE_ANTHROPIC_API_KEY=sk-ant-api03-...
VITE_ANTHROPIC_API_KEY=

# Opcional: OpenAI (só é usado se VITE_ANTHROPIC_API_KEY não estiver definida)
# VITE_OPENAI_API_KEY=sk-...
