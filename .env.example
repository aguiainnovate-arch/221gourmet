# Copie para .env e preencha com suas chaves (não versionar .env)
# cp .env.example .env

# Firebase - Console: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI — IA no app (cardápio, traduções)
VITE_OPENAI_API_KEY=

# ─── CHAVES QUE NÃO VÃO NO FRONT ──────────────────────────────────────────────
# Anthropic / Claude — moderação automática de cadastros de parceiros
# A chave fica SOMENTE no servidor (Firebase Functions secret).
# NUNCA coloque como VITE_ANTHROPIC_API_KEY — isso expõe a chave no bundle JS.
# Para configurar: firebase functions:secrets:set ANTHROPIC_API_KEY
#
# Para dev local com emulador de Functions:
#   1. firebase emulators:start --only functions
#   2. Adicione ao seu .env.local: VITE_USE_FUNCTIONS_EMULATOR=true

# Stripe — delivery (cartão online). Use a chave PUBLICÁVEL (pk_...) no front.
# A secret (sk_...) vai SOMENTE no servidor: firebase functions:secrets:set STRIPE_SECRET_KEY
VITE_STRIPE_PUBLISHABLE_KEY=

# Opcional
# VITE_APP_URL=
# VITE_UNSPLASH_ACCESS_KEY=
