# Copie para .env e preencha com suas chaves (não versionar .env)
# cp .env.example .env

# Firebase - Console: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI — cardápio / IA no app + moderação automática do cadastro de parceiros (Bora Comer): bloqueia spam/brincadeira
VITE_OPENAI_API_KEY=
# Opcional: em produção (site HTTPS), URL do SEU backend que repassa para OpenAI — o browser não pode chamar api.openai.com direto por CORS. Em `npm run dev` o Vite já usa proxy automático.
# VITE_OPENAI_MODERATION_URL=https://seu-dominio.com/api/restaurant-lead/moderate

# Claude / Anthropic — tradução ao vivo do cardápio (EN/FR quando não há tradução salva), quando usar Claude
VITE_ANTHROPIC_API_KEY=

# Opcional
# VITE_APP_URL=
# VITE_UNSPLASH_ACCESS_KEY=
