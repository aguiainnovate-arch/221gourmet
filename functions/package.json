    "openai": "^5.23.0",
    "pdf-parse": "^1.1.1",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "typescript": "~5.6.0"
  },
  "private": true
