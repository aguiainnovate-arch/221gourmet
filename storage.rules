rules_version = '2';
// Firebase Storage: regras para imagens de produtos e outros assets.
// O app usa autenticação própria (RestaurantAuthContext), não Firebase Auth,
// então request.auth é null. Por isso write está liberado com validação de tamanho e tipo.
// Se no futuro usar Firebase Auth, troque para: allow write: if request.auth != null && ...

service firebase.storage {
  match /b/{bucket}/o {

    // Imagens de produtos: restaurants/{restaurantId}/items/...
    match /restaurants/{restaurantId}/items/{itemId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 6 * 1024 * 1024  // máx 6MB
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    // Pastas legadas — mesmo bucket, sem Firebase Auth
    match /products/{fileName} {
      allow read: if true;
      allow write: if true;
    }
    match /banners/{fileName} {
      allow read: if true;
      allow write: if true;
    }
    match /audio/{fileName} {
      allow read: if true;
      allow write: if true;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
